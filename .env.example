# Fedi-Agentry Marketplace Environment Configuration

# App
NEXT_PUBLIC_APP_NAME="Fedi Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DESCRIPTION="Community marketplace bridging Fedi and Agentry"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fedi_marketplace"

# Agentry API
NEXT_PUBLIC_AGENTRY_API_URL="https://api.agentry.com"
# AGENTRY_API_KEY="your_api_key_here" # Only needed for admin operations

# WebLN Configuration
NEXT_PUBLIC_WEBLN_AUTO_ENABLE="true"

# Nostr Configuration
NEXT_PUBLIC_NOSTR_RELAY="wss://relay.agentry.com"
NEXT_PUBLIC_NOSTR_RELAY_FALLBACK="wss://relay.damus.io"

# Cashu Mint
NEXT_PUBLIC_DEFAULT_MINT_URL="https://mint.minibits.cash/Bitcoin"
# Alternative mints:
# NEXT_PUBLIC_DEFAULT_MINT_URL="https://8333.space:3338"
# NEXT_PUBLIC_DEFAULT_MINT_URL="https://mint.lnwallet.app"

# Escrow Settings
NEXT_PUBLIC_ESCROW_ENABLED="true"
NEXT_PUBLIC_ESCROW_DEFAULT_TIMEOUT_HOURS="72"

# Feature Flags
NEXT_PUBLIC_ENABLE_DIRECT_PAYMENT="true"
NEXT_PUBLIC_ENABLE_ESCROW="true"
NEXT_PUBLIC_ENABLE_MESSAGING="true"
NEXT_PUBLIC_ENABLE_RATINGS="true"

# Development
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"

# Optional: Sentry for error tracking
# SENTRY_DSN="your_sentry_dsn_here"

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID="your_analytics_id"
